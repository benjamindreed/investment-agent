# Robinhood credentials (required for trading)
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password

# NewsAPI key (optional — improves news coverage beyond yfinance)
# Get a free key at https://newsapi.org
NEWS_API_KEY=

# Scan settings (optional overrides)
MIN_MARKET_CAP=5000000000
MAX_PE_RATIO=35
MIN_VOL_RATIO=1.5
MAX_VOL_RATIO=2.0
